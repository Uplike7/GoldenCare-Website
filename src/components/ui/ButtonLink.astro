---
interface Props {
	href: string;
	variant?: "primary" | "secondary" | "ghost" | "light" | "unstyled";
	size?: "sm" | "md";
	newTab?: boolean;
	class?: string;
}

const {
	href,
	variant = "primary",
	size = "md",
	newTab = false,
	class: className = ""
} = Astro.props as Props;

const baseClasses =
	"inline-flex items-center justify-center gap-2 rounded-full font-semibold transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-green";

const variantClasses = {
	primary:
		"bg-[linear-gradient(135deg,#0b2f50,#147c68)] text-white shadow-[0_22px_48px_-24px_rgba(8,36,61,0.7)] hover:-translate-y-0.5 hover:bg-[linear-gradient(135deg,#08243d,#0f6f5d)] hover:shadow-[0_30px_60px_-26px_rgba(8,36,61,0.78)]",
	secondary:
		"border border-brand-green/20 bg-brand-cream/92 text-brand-ink shadow-[0_18px_38px_-30px_rgba(8,36,61,0.38)] hover:-translate-y-0.5 hover:border-brand-green/55 hover:bg-brand-mist",
	ghost: "text-brand-ink hover:bg-brand-mist hover:text-brand-green",
	light: "bg-brand-cream text-brand-ink shadow-[0_20px_42px_-28px_rgba(0,0,0,0.34)] hover:-translate-y-0.5 hover:bg-white",
	unstyled: ""
};

const sizeClasses = {
	sm: "px-4 py-2.5 text-sm",
	md: "px-5 py-3 text-sm sm:text-base"
};
---

<a
	href={href}
	target={newTab ? "_blank" : undefined}
	rel={newTab ? "noreferrer" : undefined}
	class:list={[baseClasses, variantClasses[variant], sizeClasses[size], className]}
>
	<slot />
</a>
