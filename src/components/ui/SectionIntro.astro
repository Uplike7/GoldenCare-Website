---
interface Props {
	eyebrow?: string;
	title: string;
	description?: string;
	align?: "left" | "center";
}

const { eyebrow, title, description, align = "left" } = Astro.props as Props;
const centered = align === "center";
---

<div class:list={["max-w-3xl space-y-4", centered && "mx-auto text-center"]}>
	{eyebrow && <p class="eyebrow">{eyebrow}</p>}
	<h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">{title}</h2>
	{description && <p class="text-lg leading-8 text-slate-600">{description}</p>}
</div>
