---
import ButtonLink from "./ButtonLink.astro";
import Container from "./Container.astro";

interface Action {
	href: string;
	label: string;
	variant?: "primary" | "secondary" | "ghost" | "light";
}

interface Props {
	eyebrow?: string;
	title: string;
	description: string;
	badges?: string[];
	actions?: Action[];
	note?: string;
}

const {
	eyebrow,
	title,
	description,
	badges = [],
	actions = [],
	note
} = Astro.props as Props;

const hasAside = Astro.slots.has("aside");
---

<section class="pb-8 pt-8 sm:pb-10 sm:pt-12">
	<Container>
		<div
			class:list={[
				"hero-panel relative overflow-hidden rounded-[2.25rem] border border-white/85 bg-brand-cream/90 p-6 shadow-[0_34px_92px_-62px_rgba(8,36,61,0.52)] sm:p-8 lg:p-10",
				hasAside && "lg:grid lg:grid-cols-[1.25fr_0.75fr] lg:items-center lg:gap-10"
			]}
		>
			<div class="pointer-events-none absolute -right-16 -top-20 h-52 w-52 rounded-full bg-brand-orange/18 blur-3xl"></div>
			<div class="pointer-events-none absolute -bottom-24 left-1/2 h-60 w-60 rounded-full bg-brand-leaf/14 blur-3xl"></div>

			<div class="relative space-y-5">
				{eyebrow && <p class="eyebrow">{eyebrow}</p>}
				<div class="space-y-3">
					<h1 class="max-w-4xl text-3xl font-semibold tracking-tight text-balance sm:text-5xl lg:text-6xl">
						{title}
					</h1>
					<p class="max-w-3xl text-base leading-7 text-slate-600 sm:text-lg">{description}</p>
				</div>

				{badges.length > 0 && (
					<div class="flex flex-wrap gap-2.5">
						{badges.map((badge) => (
							<span class="rounded-full border border-brand-gold/20 bg-brand-cream/78 px-3.5 py-1.5 text-xs font-semibold uppercase tracking-[0.12em] text-brand-navy shadow-[0_12px_26px_-24px_rgba(8,36,61,0.42)]">
								{badge}
							</span>
						))}
					</div>
				)}

				{actions.length > 0 && (
					<div class="flex flex-wrap gap-3 pt-2">
						{actions.map((action) => (
							<ButtonLink href={action.href} variant={action.variant ?? "primary"}>
								{action.label}
							</ButtonLink>
						))}
					</div>
				)}

				{note && <p class="fine-print max-w-3xl">{note}</p>}
			</div>

			{hasAside && (
				<div class="relative mt-8 grid gap-4 lg:mt-0">
					<slot name="aside" />
				</div>
			)}
		</div>
	</Container>
</section>
