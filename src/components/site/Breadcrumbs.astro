---
import Container from "../ui/Container.astro";

interface Crumb {
	label: string;
	href?: string;
}

const { items } = Astro.props as { items: Crumb[] };
---

<nav aria-label="Breadcrumb" class="pt-8">
	<Container>
		<ol class="flex flex-wrap items-center gap-2 text-sm text-slate-500">
			{items.map((item, index) => (
				<>
					<li>
						{item.href ? (
							<a href={item.href} class="hover:text-brand-green">
								{item.label}
							</a>
						) : (
							<span class="text-brand-ink">{item.label}</span>
						)}
					</li>
					{index < items.length - 1 && <li aria-hidden="true">/</li>}
				</>
			))}
		</ol>
	</Container>
</nav>
