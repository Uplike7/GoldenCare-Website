---
import Container from "../ui/Container.astro";
import Logo from "./Logo.astro";
import { companyName } from "../../data/site";

const year = new Date().getFullYear();

const serviceLinks = [
	{ href: "/day-program", label: "Day Program" },
	{ href: "/community-home-support", label: "Home & Community Staffing" },
	{ href: "/funding-resources", label: "Funding & Resources" }
];

const companyLinks = [
	{ href: "/about", label: "About" },
	{ href: "/blog", label: "Blog" },
	{ href: "/contact", label: "Contact" },
	{ href: "/apply", label: "Apply" }
];

const legalLinks = [
	{ href: "/privacy-policy", label: "Privacy Policy" },
	{ href: "/disclaimer-terms", label: "Disclaimer / Terms" }
];
---

<footer class="mt-14 border-t border-brand-line/60 bg-[linear-gradient(180deg,rgba(255,250,241,0.78),rgba(232,244,235,0.76))]">
	<Container class="py-10 sm:py-12">
		<div class="relative overflow-hidden rounded-[2.25rem] border border-white/85 bg-brand-cream/92 p-5 shadow-[0_34px_92px_-62px_rgba(8,36,61,0.52)] backdrop-blur sm:p-6 lg:p-8">
			<div class="pointer-events-none absolute -right-20 -top-20 h-48 w-48 rounded-full bg-brand-orange/18 blur-3xl"></div>
			<div class="pointer-events-none absolute -bottom-24 left-8 h-56 w-56 rounded-full bg-brand-leaf/14 blur-3xl"></div>

			<div class="relative grid gap-8 lg:grid-cols-[1.35fr_0.75fr_0.75fr_1fr]">
				<div class="max-w-sm space-y-4">
					<Logo />
					<p class="text-sm leading-6 text-slate-600">
						Adult Day Program for ages 18+ and Home & Community Staffing support for families and referral partners.
					</p>
					<p class="inline-flex rounded-full bg-brand-ink px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-white">
						Warm support. Clear next steps.
					</p>
				</div>

				<nav aria-label="Footer services" class="space-y-3">
					<h2 class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-green">Services</h2>
					<ul class="space-y-2.5">
						{serviceLinks.map((link) => (
							<li>
								<a class="text-sm font-medium text-slate-600 hover:text-brand-green" href={link.href}>
									{link.label}
								</a>
							</li>
						))}
					</ul>
				</nav>

				<nav aria-label="Footer company navigation" class="space-y-3">
					<h2 class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-green">Company</h2>
					<ul class="space-y-2.5">
						{companyLinks.map((link) => (
							<li>
								<a class="text-sm font-medium text-slate-600 hover:text-brand-green" href={link.href}>
									{link.label}
								</a>
							</li>
						))}
					</ul>
				</nav>

				<div class="space-y-3">
					<h2 class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-green">Contact</h2>
					<div class="space-y-3 text-sm leading-6 text-slate-600">
						<p class="flex items-center gap-3">
							<span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-brand-green/18 bg-brand-mist/72 text-brand-green">
								<svg aria-hidden="true" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.35 1.9.66 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.23a2 2 0 0 1 2.11-.45c.91.31 1.85.53 2.81.66A2 2 0 0 1 22 16.92Z"></path>
								</svg>
							</span>
							<a class="font-medium text-brand-ink hover:text-brand-green" href="tel:+12899920776">
								+1 (289) 992-0776
							</a>
						</p>
						<p class="flex items-center gap-3">
							<span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-brand-green/18 bg-brand-mist/72 text-brand-green">
								<svg aria-hidden="true" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z"></path>
									<path d="m22 6-10 7L2 6"></path>
								</svg>
							</span>
							<a class="break-all font-medium text-brand-ink hover:text-brand-green" href="mailto:goldencare968@gmail.com">
								goldencare968@gmail.com
							</a>
						</p>
						<p class="flex items-center gap-3">
							<span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-brand-green/18 bg-brand-mist/72 text-brand-green">
								<svg aria-hidden="true" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="12" cy="12" r="10"></circle>
									<path d="M12 6v6l4 2"></path>
								</svg>
							</span>
							<span>7:00 AM - 7:00 PM, Monday to Sunday</span>
						</p>
					</div>
					<p class="rounded-[1rem] border border-brand-gold/20 bg-brand-sand/70 px-4 py-3 text-sm leading-6 text-slate-600">
						Adult Day Program: ages 18+ in Durham Region. Home & Community Staffing: Durham, Peel, York, Toronto, and Scarborough.
					</p>
				</div>
			</div>

			<div class="relative mt-8 flex flex-col gap-3 border-t border-brand-line/70 pt-5 text-sm text-slate-500 sm:flex-row sm:items-center sm:justify-between">
				<p>&copy; {year} {companyName}. All rights reserved.</p>
				<nav aria-label="Footer legal navigation">
					<ul class="flex flex-wrap gap-x-5 gap-y-2">
						{legalLinks.map((link) => (
							<li>
								<a class="hover:text-brand-green" href={link.href}>{link.label}</a>
							</li>
						))}
					</ul>
				</nav>
			</div>
		</div>
	</Container>
</footer>
