---
import { companyName, shortName } from "../../data/site";

const compactSubtitle = "Support Services Inc.";
const logoAlt = "Golden Care Support Services Inc.";
---

<a href="/" class="inline-flex items-center gap-3 text-brand-ink" aria-label={logoAlt}>
	<img
		src="/images/golden-care-logo-mark.png"
		alt={logoAlt}
		width="900"
		height="569"
		class="h-11 w-[4.25rem] shrink-0 object-contain sm:h-12 sm:w-[4.75rem] xl:h-[3.25rem] xl:w-[5.125rem]"
		loading="eager"
		decoding="async"
	/>
	<span class="flex flex-col leading-none">
		<span class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-green xl:text-[0.95rem]">
			Golden Care
		</span>
		<span class="mt-1 hidden text-xs font-medium text-slate-500 md:block xl:hidden">
			{compactSubtitle}
		</span>
		<span class="mt-1 hidden text-xs font-medium text-slate-500 xl:block">{companyName}</span>
		<span class="mt-1 text-xs font-medium text-slate-500 md:hidden">{shortName}</span>
	</span>
</a>
