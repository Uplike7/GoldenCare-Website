---
import Container from "../ui/Container.astro";
import SectionIntro from "../ui/SectionIntro.astro";

interface Item {
	title: string;
	description: string;
}

interface Props {
	eyebrow?: string;
	title: string;
	description?: string;
	items: Item[];
}

const { eyebrow, title, description, items } = Astro.props as Props;
---

<section class="section-padding">
	<Container class="space-y-10">
		<SectionIntro eyebrow={eyebrow} title={title} description={description} />

		<div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
			{items.map((item, index) => (
				<article
					class:list={[
						"rounded-[1.45rem] p-5 shadow-[0_22px_64px_-54px_rgba(8,36,61,0.46)]",
						index % 3 === 0 && "bg-brand-cream/84",
						index % 3 === 1 && "bg-brand-mist/78",
						index % 3 === 2 && "bg-brand-sand/78"
					]}
				>
					<h3 class="text-xl font-semibold">{item.title}</h3>
					<p class="mt-3 leading-7 text-slate-600">{item.description}</p>
				</article>
			))}
		</div>
	</Container>
</section>
