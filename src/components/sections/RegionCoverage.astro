---
import Container from "../ui/Container.astro";
import SectionIntro from "../ui/SectionIntro.astro";

interface Area {
	region: string;
	note: string;
}

interface Props {
	eyebrow?: string;
	title: string;
	description?: string;
	items: Area[];
}

const { eyebrow, title, description, items } = Astro.props as Props;
---

<section class="section-padding">
	<Container class="space-y-10">
		<SectionIntro eyebrow={eyebrow} title={title} description={description} />

		<div class="grid gap-5 md:grid-cols-2">
			{items.map((item) => (
				<article class="surface-card p-6">
					<h3 class="text-xl font-semibold">{item.region}</h3>
					<p class="mt-3 leading-7 text-slate-600">{item.note}</p>
				</article>
			))}
		</div>
	</Container>
</section>
