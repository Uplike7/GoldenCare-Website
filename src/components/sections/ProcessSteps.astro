---
import Container from "../ui/Container.astro";
import SectionIntro from "../ui/SectionIntro.astro";

interface Step {
	title: string;
	description: string;
}

interface Props {
	eyebrow?: string;
	title: string;
	description?: string;
	items: Step[];
}

const { eyebrow, title, description, items } = Astro.props as Props;
---

<section class="section-padding">
	<Container class="space-y-10">
		<SectionIntro eyebrow={eyebrow} title={title} description={description} />

		<div class="tint-panel grid gap-4 p-4 sm:p-5 lg:grid-cols-4">
			{items.map((item, index) => (
				<article class="step-card">
					<span class="step-marker">{index + 1}</span>
					<h3 class="mt-3 text-xl font-semibold">{item.title}</h3>
					<p class="mt-3 leading-7 text-slate-600">{item.description}</p>
				</article>
			))}
		</div>
	</Container>
</section>
