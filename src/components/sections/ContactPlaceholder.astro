---
import Container from "../ui/Container.astro";
import SectionIntro from "../ui/SectionIntro.astro";

interface Props {
	eyebrow?: string;
	title: string;
	description?: string;
	formLabel: string;
	notes: string[];
}

const { eyebrow, title, description, formLabel, notes } = Astro.props as Props;
---

<section class="section-padding">
	<Container class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
		<SectionIntro eyebrow={eyebrow} title={title} description={description} />

		<div class="feature-panel p-5 sm:p-6">
			<div class="rounded-[1.5rem] border border-dashed border-brand-green/30 bg-[linear-gradient(135deg,rgba(255,247,235,0.78),rgba(237,246,243,0.74))] px-5 py-8 text-center sm:px-6">
				<p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-green">Form area</p>
				<h3 class="mt-3 text-2xl font-semibold">{formLabel}</h3>
				<p class="mt-3 leading-7 text-slate-600">
					Online form access will appear here. For now, contact Golden Care.
				</p>
			</div>

			<ul class="mt-6 space-y-3 text-sm leading-6 text-slate-600">
				{notes.map((note) => (
					<li class="flex gap-3">
						<span class="mt-2 h-2 w-2 rounded-full bg-brand-gold"></span>
						<span>{note}</span>
					</li>
				))}
			</ul>
		</div>
	</Container>
</section>
