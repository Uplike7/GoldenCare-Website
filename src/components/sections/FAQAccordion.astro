---
import Container from "../ui/Container.astro";
import SectionIntro from "../ui/SectionIntro.astro";

interface FAQItem {
	question: string;
	answer: string;
}

interface Props {
	eyebrow?: string;
	title: string;
	description?: string;
	items: FAQItem[];
}

const { eyebrow, title, description, items } = Astro.props as Props;
---

<section class="section-padding">
	<Container class="space-y-10">
		<SectionIntro eyebrow={eyebrow} title={title} description={description} />

		<div class="tint-panel space-y-3 p-4 sm:p-5">
			{items.map((item) => (
				<details class="group rounded-[1.25rem] border border-white/75 bg-brand-cream/78 p-5 shadow-[0_16px_42px_-38px_rgba(8,36,61,0.4)] transition open:bg-white/94">
					<summary class="flex cursor-pointer list-none items-center justify-between gap-5 text-base font-semibold text-brand-ink sm:text-lg">
						{item.question}
						<span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-mist text-brand-green transition group-open:rotate-45">
							+
						</span>
					</summary>
					<p class="mt-4 max-w-4xl leading-7 text-slate-600">{item.answer}</p>
				</details>
			))}
		</div>
	</Container>
</section>
