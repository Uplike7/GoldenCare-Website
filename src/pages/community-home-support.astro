---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import ButtonLink from "../components/ui/ButtonLink.astro";

const supportCards = [
	{
		title: "Families and private homes",
		description: "For children, youth, adults, or seniors needing respite, supervision, or 1:1 support."
	},
	{
		title: "Group homes and supported settings",
		description: "Coverage for homes and care environments needing dependable staff."
	},
	{
		title: "Shelters and community agencies",
		description: "Relief, coverage, or program support for community-based organizations."
	},
	{
		title: "Schools and youth-support environments",
		description: "Structured support where children or youth need extra assistance."
	},
	{
		title: "Private care companies",
		description: "Partnership staffing support for agencies needing trained workers."
	},
	{
		title: "Community settings",
		description: "Support for outings, appointments, activities, errands, and participation."
	}
];

// Swap these image paths when stronger Home & Community Staffing photography is ready.
const supportSettingPhotos = [
	{
		src: "/images/family-support.jpg",
		alt: "Caregiver providing calm support during an outdoor community activity"
	},
	{
		src: "/images/blog-community-support.jpg",
		alt: "Support worker sharing a structured activity moment in a home or community setting"
	},
	{
		src: "/images/home-hero.jpg",
		alt: "Hands-on life-skills activity materials for supportive daily routines"
	},
	{
		src: "/images/blog-day-program.jpg",
		alt: "Prepared activity materials representing guided participation and routine support"
	},
	{
		src: "/images/blog-funding.jpg",
		alt: "Planning materials representing coordinated support coverage and next steps"
	}
];

const supportSettingPhotoSlides = [...supportSettingPhotos, ...supportSettingPhotos].map((photo, index) => ({
	photo,
	set: index < supportSettingPhotos.length ? "original" : "duplicate"
}));

const supportSettingPhotoCount = supportSettingPhotos.length;
const supportSettingSlideshowLabel = `Home and community support setting photo story with ${supportSettingPhotoCount} photos`;

const supportTypes = [
	{
		title: "1:1 support",
		description: "Focused support for individuals who need direct assistance and supervision."
	},
	{
		title: "Respite and relief coverage",
		description: "Practical coverage that helps caregivers and teams plan around support needs."
	},
	{
		title: "Community access support",
		description: "Support for safe participation in appointments, activities, errands, and outings."
	},
	{
		title: "Program or shift coverage",
		description: "Support workers for care settings, programs, or organizations needing coverage."
	}
];

const staffReadiness = [
	{
		title: "First Aid & CPR",
		description: "Basic emergency-response readiness where required or applicable."
	},
	{
		title: "Behaviour support awareness",
		description: "UMAB, behaviour-support training, or related preparation where applicable."
	},
	{
		title: "Crisis intervention",
		description: "Calm response, redirection, and de-escalation during challenging moments."
	},
	{
		title: "Documentation and reporting",
		description: "Daily notes, incident reporting, communication logs, and follow-up where required."
	},
	{
		title: "Person-centred support",
		description: "Support shaped around routines, communication style, dignity, goals, and comfort."
	},
	{
		title: "Complex-needs experience",
		description: "Experience may include autism, developmental disabilities, mental health, behavioural needs, or related support settings."
	}
];

const nextSteps = [
	{
		title: "Apply for staffing",
		description: "Tell us where support is needed, who needs support, the schedule, and the type of coverage you are looking for."
	},
	{
		title: "Find the best coverage fit",
		description: "We review the setting, timing, support needs, location, and staffing availability."
	},
	{
		title: "Plan next steps",
		description: "We follow up with intake details, scheduling options, and next steps."
	}
];
---

<BaseLayout
	title="Home & Community Support Staffing | Golden Care Support Services Inc."
	description="Request staffing support for children, youth, adults, and seniors with complex needs across homes, community settings, and partner care environments."
>
	<section class="pb-7 pt-7 sm:pb-9 sm:pt-9">
		<Container>
			<div class="hero-panel relative overflow-hidden rounded-[2.3rem] border border-white/85 bg-brand-cream/90 p-4 shadow-[0_38px_98px_-60px_rgba(8,36,61,0.56)] sm:p-5 lg:grid lg:min-h-[34rem] lg:grid-cols-[0.84fr_1.16fr] lg:gap-7 lg:p-6">
				<div class="pointer-events-none absolute -right-24 -top-24 h-64 w-64 rounded-full bg-brand-orange/18 blur-3xl"></div>
				<div class="pointer-events-none absolute bottom-0 left-12 h-56 w-56 rounded-full bg-brand-leaf/14 blur-3xl"></div>

				<div class="relative flex flex-col justify-center px-1 py-4 sm:px-3 lg:px-4">
					<div class="max-w-3xl space-y-3">
						<p class="eyebrow">Home, Community & Staffing Support</p>
						<h1 class="text-3xl font-semibold tracking-tight text-balance sm:text-5xl">
							Support staffing for homes, communities, and care settings.
						</h1>
						<p class="max-w-2xl text-base leading-7 text-slate-600 sm:text-lg">
							Golden Care provides trained support workers for families, individuals, group homes, shelters, schools, private care companies, and community organizations that need dependable staffing support.
						</p>
						<p class="max-w-2xl text-sm leading-6 text-slate-600 sm:text-base">
							Support can be arranged for children, youth, adults, and seniors with complex needs, depending on location, schedule, staffing availability, and fit.
						</p>
					</div>

					<div class="mt-6 flex flex-wrap gap-3">
						<ButtonLink href="/apply#community-support-request">Request Support</ButtonLink>
						<ButtonLink href="/contact" variant="secondary">Ask About Staffing</ButtonLink>
					</div>
				</div>

				<div class="relative mt-7 lg:mt-0">
					<div class="relative h-full min-h-[24rem] overflow-hidden rounded-[2rem] bg-[linear-gradient(145deg,#e8f4eb,#fff1dd)] p-2.5 shadow-[0_30px_84px_-58px_rgba(8,36,61,0.5)] sm:min-h-[28rem]">
						<img
							src="/images/family-support.jpg"
							alt="Caregiver supporting children during an outdoor community activity"
							class="h-full min-h-[22.5rem] w-full rounded-[1.55rem] object-cover object-[62%_58%] sm:min-h-[26.5rem]"
							loading="eager"
							decoding="async"
						/>
						<div class="pointer-events-none absolute inset-2.5 rounded-[1.55rem] bg-[linear-gradient(180deg,rgba(8,36,61,0)_50%,rgba(8,36,61,0.18))]"></div>
					</div>
				</div>
			</div>
		</Container>
	</section>

	<section class="pb-8 pt-1 sm:pb-10">
		<Container>
			<div class="relative overflow-hidden rounded-[2rem] border border-white/80 bg-brand-cream/92 p-4 shadow-[0_26px_74px_-62px_rgba(8,36,61,0.48)] sm:p-5 lg:p-6">
				<div class="pointer-events-none absolute -right-16 -top-16 h-52 w-52 rounded-full bg-brand-orange/14 blur-3xl"></div>
				<div class="relative">
					<div class="max-w-4xl">
						<p class="eyebrow">Who we support</p>
						<h2 class="mt-3 text-2xl font-semibold tracking-tight sm:text-3xl">
							Staffing support for people and organizations that need coverage.
						</h2>
						<p class="mt-3 text-sm leading-6 text-slate-600 sm:text-base">
							Whether support is needed at home, in the community, or within a care setting, Golden Care helps arrange dependable workers based on the person&apos;s needs and the setting.
						</p>
					</div>

					<div class="mt-5 grid gap-4 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
						<div class="relative min-h-[16rem] overflow-hidden rounded-[1.6rem] bg-[linear-gradient(145deg,#fff1dd,#e8f4eb)] p-2.5 shadow-[0_24px_70px_-58px_rgba(8,36,61,0.48)] sm:min-h-[18rem] lg:min-h-[22rem]">
							<div
								class="support-settings-slideshow h-full min-h-[15rem] overflow-hidden rounded-[1.25rem] sm:min-h-[17rem] lg:min-h-[21rem]"
								data-support-settings-slideshow
								tabindex="0"
								aria-label={supportSettingSlideshowLabel}
								aria-roledescription="carousel"
							>
								<div class="support-settings-slideshow-track flex h-full" data-support-settings-slideshow-track>
									{supportSettingPhotoSlides.map(({ photo, set }) => (
										<figure
											class="support-settings-slideshow-slide h-full min-w-full"
											data-support-settings-slide-set={set}
											aria-hidden={set === "duplicate" ? "true" : undefined}
										>
											<img
												src={photo.src}
												alt={photo.alt}
												class="h-full min-h-[15rem] w-full rounded-[1.25rem] object-cover object-[58%_52%] sm:min-h-[17rem] lg:min-h-[21rem]"
												loading="lazy"
											/>
										</figure>
									))}
								</div>
							</div>
						</div>

						<div class="grid gap-2.5 sm:grid-cols-2">
							{supportCards.map((setting) => (
								<article class="rounded-[1.1rem] border border-brand-green/14 bg-white/64 p-3.5 shadow-[0_14px_42px_-38px_rgba(8,36,61,0.28)]">
									<h3 class="text-sm font-semibold leading-5 text-brand-ink sm:text-base">{setting.title}</h3>
									<p class="mt-1.5 text-sm leading-5 text-slate-600">{setting.description}</p>
								</article>
							))}
						</div>
					</div>
				</div>
			</div>
		</Container>
	</section>

	<section class="pb-8 pt-1 sm:pb-10">
		<Container>
			<div class="mb-5 flex flex-col gap-2 sm:mb-6">
				<p class="eyebrow">Staffing may support</p>
				<h2 class="max-w-3xl text-2xl font-semibold tracking-tight sm:text-3xl">
					Practical staffing for real-life support needs.
				</h2>
			</div>

			<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
				{supportTypes.map((support) => (
					<article class="service-card min-h-full">
						<h3 class="text-lg font-semibold tracking-tight">{support.title}</h3>
						<p class="mt-3 text-sm leading-6 text-slate-600">{support.description}</p>
					</article>
				))}
			</div>
		</Container>
	</section>

	<section class="pb-8 pt-1 sm:pb-10">
		<Container>
			<div class="relative overflow-hidden rounded-[2.2rem] border border-white/82 bg-[linear-gradient(145deg,#fffaf1,#e8f4eb_62%,#fff1dd)] p-5 shadow-[0_32px_88px_-62px_rgba(8,36,61,0.52)] sm:p-6 lg:grid lg:grid-cols-[0.82fr_1.18fr] lg:gap-6 lg:p-7">
				<div class="pointer-events-none absolute -left-20 -top-24 h-64 w-64 rounded-full bg-brand-leaf/14 blur-3xl"></div>
				<div class="pointer-events-none absolute -right-16 -bottom-20 h-56 w-56 rounded-full bg-brand-orange/14 blur-3xl"></div>

				<div class="relative">
					<p class="eyebrow">Staff readiness</p>
					<h2 class="mt-4 text-2xl font-semibold tracking-tight sm:text-3xl">
						Workers prepared for complex-needs environments.
					</h2>
					<p class="mt-4 text-base leading-7 text-slate-600">
						Golden Care focuses on dependable support workers who understand structure, communication, safety, and calm follow-through. Staff experience and training may vary by role and setting, but may include preparation for home, community, shelter, group-home, school, and care-setting environments.
					</p>
					<p class="mt-3 rounded-[1.1rem] border border-brand-green/16 bg-brand-leaf/12 px-4 py-3 text-sm leading-6 text-slate-700">
						Staff matching depends on support needs, setting, schedule, availability, and fit.
					</p>
				</div>

				<div class="relative mt-5 grid gap-3 sm:grid-cols-2 lg:mt-0">
					{staffReadiness.map((point) => (
						<div class="rounded-[1.15rem] border border-white/78 bg-brand-cream/84 px-4 py-3 shadow-[0_18px_52px_-46px_rgba(8,36,61,0.38)]">
							<h3 class="text-sm font-semibold leading-5 text-brand-ink">{point.title}</h3>
							<p class="mt-1.5 text-sm leading-5 text-slate-600">{point.description}</p>
						</div>
					))}
				</div>
			</div>
		</Container>
	</section>

	<section class="pb-8 pt-1 sm:pb-10">
		<Container>
			<div class="relative overflow-hidden rounded-[2.2rem] border border-white/80 bg-brand-cream/92 p-5 shadow-[0_30px_84px_-62px_rgba(8,36,61,0.5)] sm:p-6 lg:grid lg:grid-cols-[0.86fr_1.14fr] lg:gap-6 lg:p-7">
				<div class="pointer-events-none absolute -right-16 -top-16 h-52 w-52 rounded-full bg-brand-orange/14 blur-3xl"></div>
				<div class="relative">
					<p class="eyebrow">Request staffing support</p>
					<h2 class="mt-4 text-2xl font-semibold tracking-tight sm:text-3xl">
						Request staffing support for your home, program, or care setting.
					</h2>
					<p class="mt-4 text-base leading-7 text-slate-600">
						Tell us where support is needed, who needs support, the schedule you are looking for, and the type of coverage required. Staffing support may be available across Durham, Peel, York, Toronto, and Scarborough depending on staffing availability, support needs, location, and fit.
					</p>
				</div>

				<div class="relative mt-5 grid gap-3 lg:mt-0">
					{nextSteps.map((step, index) => (
						<div class="rounded-[1.25rem] border border-white/78 bg-[linear-gradient(145deg,rgba(255,250,241,0.95),rgba(232,244,235,0.78))] p-4 shadow-[0_18px_52px_-46px_rgba(8,36,61,0.42)] sm:grid sm:grid-cols-[auto_1fr] sm:items-start sm:gap-4">
							<span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-brand-gold/60 bg-[linear-gradient(135deg,#147c68,#0f6c5f)] text-base font-bold text-white shadow-[0_18px_40px_-18px_rgba(20,124,104,0.9),0_0_0_1px_rgba(237,170,68,0.24)] ring-[5px] ring-brand-gold/20">
								{index + 1}
							</span>
							<div>
								<h3 class="text-base font-semibold text-brand-ink">{step.title}</h3>
								<p class="mt-1 text-sm leading-6 text-slate-600">{step.description}</p>
							</div>
						</div>
					))}
				</div>
			</div>
		</Container>
	</section>

	<section class="pb-10 pt-1 sm:pb-12">
		<Container>
			<div class="cta-panel lg:flex lg:items-center lg:justify-between lg:gap-8">
				<div class="max-w-2xl">
					<p class="text-sm font-semibold uppercase tracking-[0.18em] text-white/76">Ready to request support?</p>
					<h2 class="mt-3 text-2xl font-semibold tracking-tight text-white sm:text-3xl">
						Apply for staffing or support coverage.
					</h2>
					<p class="mt-3 text-sm leading-6 text-white/80">
						Families, group homes, shelters, schools, private care companies, and community organizations can reach out to request support.
					</p>
				</div>

				<div class="mt-5 flex flex-wrap gap-3 lg:mt-0">
					<ButtonLink href="/apply#community-support-request" variant="light">Request Staffing</ButtonLink>
					<ButtonLink
						href="/contact"
						variant="unstyled"
						class="border border-white/30 bg-white/10 px-5 py-3 text-sm text-white hover:-translate-y-0.5 hover:bg-white/18 sm:text-base"
					>
						Talk to Us
					</ButtonLink>
				</div>
			</div>
		</Container>
	</section>

	<style>
		.support-settings-slideshow {
			scrollbar-width: none;
			-ms-overflow-style: none;
		}

		.support-settings-slideshow::-webkit-scrollbar {
			display: none;
		}

		.support-settings-slideshow:focus-visible {
			outline: 2px solid #147c68;
			outline-offset: 0.32rem;
		}

		.support-settings-slideshow-track {
			transform: translate3d(0, 0, 0);
			transition: transform 760ms cubic-bezier(0.22, 1, 0.36, 1);
			will-change: transform;
		}

		.support-settings-slideshow-slide {
			flex: 0 0 100%;
			width: 100%;
		}

		@media (prefers-reduced-motion: reduce) {
			.support-settings-slideshow-track {
				transition: none;
			}
		}
	</style>

	<script is:inline>
		const supportSettingsSlideshow = document.querySelector("[data-support-settings-slideshow]");

		if (supportSettingsSlideshow) {
			const supportSettingsTrack = supportSettingsSlideshow.querySelector("[data-support-settings-slideshow-track]");
			const originalSupportSettingsSlides = Array.from(
				supportSettingsSlideshow.querySelectorAll("[data-support-settings-slide-set='original']")
			);
			const supportSettingsSlideCount = originalSupportSettingsSlides.length;
			const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
			const supportSettingsIntervalDelay = 5200;
			let activeSupportSettingsIndex = 0;
			let supportSettingsTimer;
			let isHoveringSupportSettings = false;
			let isFocusingSupportSettings = false;

			const moveSupportSettingsTrack = (index, shouldAnimate = true) => {
				if (!supportSettingsTrack) return;
				activeSupportSettingsIndex = index;

				if (!shouldAnimate) {
					supportSettingsTrack.style.transition = "none";
				}

				supportSettingsTrack.style.transform = `translate3d(-${activeSupportSettingsIndex * 100}%, 0, 0)`;

				if (!shouldAnimate) {
					supportSettingsTrack.offsetHeight;
					supportSettingsTrack.style.transition = "";
				}
			};

			const normalizeSupportSettingsTrack = () => {
				if (!supportSettingsSlideCount) return;
				if (activeSupportSettingsIndex < supportSettingsSlideCount) return;
				moveSupportSettingsTrack(activeSupportSettingsIndex % supportSettingsSlideCount, false);
			};

			const shouldPauseSupportSettingsAuto = () => isHoveringSupportSettings || isFocusingSupportSettings;

			const stopSupportSettingsAuto = () => {
				window.clearInterval(supportSettingsTimer);
				supportSettingsTimer = undefined;
			};

			const startSupportSettingsAuto = () => {
				if (prefersReducedMotion || shouldPauseSupportSettingsAuto() || supportSettingsTimer || !supportSettingsSlideCount) return;
				supportSettingsTimer = window.setInterval(() => {
					moveSupportSettingsTrack(activeSupportSettingsIndex + 1);
				}, supportSettingsIntervalDelay);
			};

			supportSettingsTrack?.addEventListener("transitionend", (event) => {
				if (event.propertyName !== "transform") return;
				normalizeSupportSettingsTrack();
			});

			supportSettingsSlideshow.addEventListener("mouseenter", () => {
				isHoveringSupportSettings = true;
				stopSupportSettingsAuto();
			});

			supportSettingsSlideshow.addEventListener("mouseleave", () => {
				isHoveringSupportSettings = false;
				startSupportSettingsAuto();
			});

			supportSettingsSlideshow.addEventListener("focusin", () => {
				isFocusingSupportSettings = true;
				stopSupportSettingsAuto();
			});

			supportSettingsSlideshow.addEventListener("focusout", (event) => {
				if (!supportSettingsSlideshow.contains(event.relatedTarget)) {
					isFocusingSupportSettings = false;
					startSupportSettingsAuto();
				}
			});

			startSupportSettingsAuto();
		}
	</script>
</BaseLayout>
