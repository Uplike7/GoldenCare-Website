---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import ButtonLink from "../components/ui/ButtonLink.astro";

const supportGroups = [
	{
		title: "Who receives support",
		items: [
			{
				title: "Children, youth, and adults who need structured, dependable support",
				description: "Including individuals who benefit from calm routines, guided activity, and more consistent day-to-day support."
			},
			{
				title: "Individuals with autism, ADHD, developmental disabilities, mental health challenges, or related complex needs",
				description: "Support is shaped around communication, safety, routines, and the realities of everyday life."
			}
		]
	},
	{
		title: "Who we work with",
		items: [
			{
				title: "Families and caregivers looking for respite, community participation, life-skills support, or 1:1 help",
				description: "We aim to make support feel more practical, organized, and easier to plan around."
			},
			{
				title: "Referral partners seeking a clear, affordable, and dependable support option",
				description: "Golden Care provides a more structured first step for people who need real support and follow-through."
			}
		]
	}
];
---

<BaseLayout
	title="About Golden Care Support Services Inc."
	description="Learn about Golden Care, a privately owned support-services company helping families access structured support for complex needs."
>
	<section class="pb-8 pt-7 sm:pb-10 sm:pt-10">
		<Container>
			<div class="relative overflow-hidden rounded-[2.35rem] bg-[linear-gradient(135deg,rgba(255,250,241,0.98),rgba(232,244,235,0.86))] p-5 shadow-[0_36px_96px_-62px_rgba(8,36,61,0.58)] sm:p-7 lg:grid lg:grid-cols-[1fr_0.9fr] lg:gap-8 lg:p-9">
				<div class="absolute -right-20 top-0 h-64 w-64 rounded-full bg-brand-orange/18 blur-3xl"></div>
				<div class="absolute bottom-0 left-10 h-56 w-56 rounded-full bg-brand-leaf/14 blur-3xl"></div>

				<div class="relative flex flex-col justify-center">
					<p class="eyebrow">About Golden Care</p>
					<h1 class="mt-5 max-w-4xl text-4xl font-semibold tracking-tight text-balance sm:text-5xl lg:text-[3.35rem] lg:leading-[1.05]">
						A privately owned support company for families navigating complex needs.
					</h1>
					<p class="mt-5 max-w-3xl text-base leading-7 text-slate-600 sm:text-lg">
						Golden Care helps families, caregivers, and referral partners access structured, affordable support for children, youth, and adults with complex needs and diagnoses.
					</p>
					<div class="mt-7 flex flex-wrap gap-3">
						<span class="rounded-full bg-brand-cream/82 px-4 py-2 text-sm font-semibold text-brand-ink shadow-[0_14px_34px_-28px_rgba(8,36,61,0.42)]">
							Privately owned
						</span>
						<span class="rounded-full bg-brand-cream/82 px-4 py-2 text-sm font-semibold text-brand-ink shadow-[0_14px_34px_-28px_rgba(8,36,61,0.42)]">
							Structured support
						</span>
						<span class="rounded-full bg-brand-cream/82 px-4 py-2 text-sm font-semibold text-brand-ink shadow-[0_14px_34px_-28px_rgba(8,36,61,0.42)]">
							Children, youth, adults, and families
						</span>
					</div>
				</div>

				<div class="relative mt-8 lg:mt-0">
					<div class="relative min-h-[22rem] overflow-hidden rounded-[2rem] bg-[linear-gradient(145deg,#fff1dd,#e8f4eb)] p-2.5 shadow-[0_30px_78px_-56px_rgba(8,36,61,0.56)]">
						<div class="absolute -right-12 -top-12 h-44 w-44 rounded-full bg-brand-orange/24 blur-2xl"></div>
						<div class="absolute -bottom-16 left-8 h-52 w-52 rounded-full bg-brand-leaf/18 blur-2xl"></div>
						<div class="relative min-h-[19rem] overflow-hidden rounded-[1.6rem] bg-brand-cream/46 backdrop-blur sm:min-h-[22rem]">
							<img
								src="/images/family-support.jpg"
								alt="Children and a caregiver sharing a warm support moment outdoors"
								class="h-full min-h-[19rem] w-full object-cover object-[58%_55%] sm:min-h-[22rem]"
								loading="eager"
								decoding="async"
							/>
							<div class="pointer-events-none absolute inset-0 bg-[linear-gradient(180deg,rgba(255,250,241,0.02),rgba(8,36,61,0.16))]"></div>
						</div>
					</div>
				</div>
			</div>
		</Container>
	</section>

	<section class="pb-10 pt-2">
		<Container>
			<div class="relative">
				<div
					aria-hidden="true"
					class="pointer-events-none absolute -inset-1 rounded-[2.45rem] bg-[linear-gradient(135deg,#08243d,#147c68)]"
					style="-webkit-mask-image: linear-gradient(to right, transparent 0, #000 18px, #000 calc(100% - 18px), transparent 100%), linear-gradient(to bottom, transparent 0, #000 18px, #000 calc(100% - 18px), transparent 100%); -webkit-mask-composite: source-in; mask-image: linear-gradient(to right, transparent 0, #000 18px, #000 calc(100% - 18px), transparent 100%), linear-gradient(to bottom, transparent 0, #000 18px, #000 calc(100% - 18px), transparent 100%); mask-composite: intersect;"
				></div>
				<div class="relative rounded-[2.25rem] p-5 text-white shadow-[0_34px_90px_-58px_rgba(8,36,61,0.72)] sm:p-7 lg:p-8">
				<div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden rounded-[2.25rem] bg-[linear-gradient(135deg,#08243d,#147c68)]">
					<div class="absolute -right-20 -top-16 h-64 w-64 rounded-full bg-brand-orange/22 blur-3xl"></div>
					<div class="absolute -bottom-20 left-8 h-56 w-56 rounded-full bg-brand-leaf/16 blur-3xl"></div>
					<div class="absolute inset-0 bg-[radial-gradient(circle_at_18%_20%,rgba(255,250,241,0.11),transparent_28%),radial-gradient(circle_at_82%_14%,rgba(239,143,58,0.12),transparent_30%),linear-gradient(180deg,rgba(255,255,255,0.035),transparent_42%)]"></div>
					<div class="absolute inset-0 rounded-[2.25rem] bg-[radial-gradient(circle_at_0%_0%,rgba(255,250,241,0.13),transparent_30%),radial-gradient(circle_at_100%_0%,rgba(255,241,221,0.11),transparent_30%),radial-gradient(circle_at_0%_100%,rgba(232,244,235,0.1),transparent_32%),radial-gradient(circle_at_100%_100%,rgba(255,250,241,0.08),transparent_32%)] shadow-[inset_0_0_0_1px_rgba(255,255,255,0.11),inset_0_0_54px_rgba(255,250,241,0.075)]"></div>
				</div>

				<div class="relative grid gap-6 lg:grid-cols-[0.42fr_0.58fr] lg:items-stretch">
					<div class="flex flex-col gap-4">
						<div class="rounded-[1.6rem] border border-white/14 bg-white/10 p-5 shadow-[0_24px_58px_-48px_rgba(0,0,0,0.58)] backdrop-blur sm:p-6">
							<p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-gold">Who we are</p>
							<p class="mt-5 text-[4rem] font-semibold leading-none tracking-tight text-white sm:text-7xl">20+</p>
							<p class="mt-2.5 max-w-xs text-sm font-semibold uppercase tracking-[0.16em] text-white/72">
								Years of frontline experience
							</p>
						</div>

						<div class="relative min-h-[14rem] overflow-hidden rounded-[1.6rem] border border-white/14 bg-brand-cream/18 p-2 shadow-[0_24px_58px_-48px_rgba(0,0,0,0.58)]">
							<img
								src="/images/home-hero.jpg"
								alt="Adults taking part in a guided creative support activity"
								class="h-full min-h-[13rem] w-full rounded-[1.25rem] object-cover object-[66%_52%]"
								loading="lazy"
								decoding="async"
							/>
							<div class="pointer-events-none absolute inset-0 bg-[linear-gradient(180deg,rgba(255,250,241,0.02),rgba(8,36,61,0.22))]"></div>
							<div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_45%,rgba(8,36,61,0.2)_100%)]"></div>
							<div class="pointer-events-none absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-brand-ink/24 to-transparent"></div>
						</div>
					</div>

					<div class="rounded-[1.75rem] bg-brand-cream/94 p-5 text-brand-ink shadow-[0_28px_72px_-52px_rgba(0,0,0,0.5)] sm:p-6 lg:p-7">
						<h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">
							Built from frontline experience. Shaped by what families need.
						</h2>
						<div class="mt-5 space-y-3 text-base leading-7 text-slate-600">
							<p>
								Golden Care was built on over 20 years of frontline experience supporting individuals with complex needs. That work revealed real gaps: unclear systems, inconsistent communication, and care that did not always feel practical or responsive.
							</p>
							<p>
								We created Golden Care to help raise the standard with structured, dependable, modern support for children, youth, and adults who need steady follow-through.
							</p>
						</div>

						<div class="mt-5 rounded-[1.35rem] border border-brand-leaf/24 bg-white/48 p-4 sm:p-5">
							<p class="inline-flex rounded-full bg-brand-green px-3 py-1.5 text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-white shadow-[0_16px_34px_-24px_rgba(8,36,61,0.52)]">
								Our mission
							</p>
							<h3 class="mt-3 text-xl font-semibold tracking-tight sm:text-2xl">
								Make dependable support more accessible for individuals and families in need.
							</h3>
							<p class="mt-3 text-sm leading-6 text-slate-600">
								We help families move from uncertainty to a practical next step by planning around goals, safety, communication, routines, and family context.
							</p>
						</div>
					</div>
				</div>
				</div>
			</div>
		</Container>
	</section>

	<section class="pb-10 pt-2">
		<Container>
			<div class="relative overflow-hidden rounded-[2.25rem] bg-[linear-gradient(145deg,#fffaf1,#e8f4eb_56%,#fff1dd)] p-3 shadow-[0_30px_84px_-62px_rgba(8,36,61,0.5)] sm:p-4 lg:p-5">
				<div class="pointer-events-none absolute -right-20 -top-20 h-56 w-56 rounded-full bg-brand-orange/18 blur-3xl"></div>
				<div class="pointer-events-none absolute -bottom-24 left-16 h-64 w-64 rounded-full bg-brand-leaf/16 blur-3xl"></div>

				<div class="relative mx-auto max-w-4xl px-2 pt-2 text-center sm:px-3 sm:pt-3">
					<p class="eyebrow">Mission and values</p>
					<h2 class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl">
						Rooted in values. Built around people.
					</h2>
					<p class="mx-auto mt-4 max-w-3xl text-base leading-7 text-slate-600">
						Our values shape how we plan, communicate, and support each person and family. They guide the way we build routines, respond to needs, and create dependable next steps.
					</p>
				</div>

				<div class="relative mt-6 overflow-hidden rounded-[1.9rem] border border-white/78 bg-brand-cream/86 p-1.5 shadow-[0_28px_78px_-56px_rgba(8,36,61,0.54)] sm:p-2">
					<img
						src="/images/golden-care-values-tree.png"
						alt="Golden Care values tree showing person-centred support, family collaboration, structured support, complex-needs experience, care, trust, safety, dignity, compassion, communication, consistency, respect, and support."
						class="h-auto w-full rounded-[1.45rem] object-contain"
						loading="lazy"
						decoding="async"
					/>
				</div>
			</div>
		</Container>
	</section>

	<section class="pb-10 pt-2">
		<Container>
			<div class="relative overflow-hidden rounded-[2.25rem] border border-white/80 bg-[linear-gradient(145deg,#fffaf1,#e8f4eb_62%,#fff1dd)] p-5 shadow-[0_32px_92px_-64px_rgba(8,36,61,0.56)] sm:p-7 lg:p-8">
				<div class="pointer-events-none absolute -right-20 -top-20 h-56 w-56 rounded-full bg-brand-orange/16 blur-3xl"></div>
				<div class="pointer-events-none absolute -bottom-24 left-12 h-64 w-64 rounded-full bg-brand-leaf/15 blur-3xl"></div>
				<div class="relative">
					<p class="eyebrow">Who we support</p>
					<h2 class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl">
						Support for children, youth, adults, and the people who care for them.
					</h2>
					<p class="mt-4 max-w-3xl text-base leading-7 text-slate-600">
						We support individuals with autism, ADHD, developmental disabilities, mental health challenges, and other layered support needs, while helping families, caregivers, and referral partners find a clearer next step.
					</p>
					<div class="mt-6 grid gap-4 lg:grid-cols-2">
						{supportGroups.map((group, groupIndex) => (
							<div class:list={[
								"relative overflow-hidden rounded-[1.65rem] border border-white/78 p-5 shadow-[0_24px_72px_-58px_rgba(8,36,61,0.52)] sm:p-6",
								groupIndex === 0 ? "bg-brand-cream/86" : "bg-brand-cream/78"
							]}>
								<div class="pointer-events-none absolute -right-10 -top-10 h-32 w-32 rounded-full bg-brand-orange/10 blur-2xl"></div>
								<div class="relative flex items-center gap-4 border-b border-brand-leaf/18 pb-4">
									<span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-[linear-gradient(135deg,#08243d,#147c68)] text-sm font-semibold text-white shadow-[0_18px_38px_-26px_rgba(8,36,61,0.58)]">
										0{groupIndex + 1}
									</span>
									<h3 class="text-xl font-semibold tracking-tight text-brand-ink">{group.title}</h3>
								</div>

								<div class="relative mt-5 space-y-5">
									{group.items.map((item) => (
										<div class="grid gap-2 border-l-2 border-brand-green/32 pl-4">
											<h4 class="text-base font-semibold leading-6 tracking-tight text-brand-ink">
												{item.title}
											</h4>
											<p class="text-sm leading-6 text-slate-600">{item.description}</p>
										</div>
									))}
								</div>
							</div>
						))}
					</div>
					<div class="mt-6 flex justify-center">
						<p class="max-w-4xl rounded-full border border-brand-green/24 bg-brand-cream/92 px-5 py-3.5 text-center text-[0.92rem] font-bold leading-6 text-brand-ink shadow-[0_22px_58px_-44px_rgba(8,36,61,0.5)] backdrop-blur sm:px-6">
							Adult Day Program: ages 18+ in Durham Region <span class="mx-3 text-brand-green sm:mx-4">&bull;</span> Home &amp; Community Staffing: Durham, Peel, York, Toronto, and Scarborough
						</p>
					</div>
				</div>
			</div>
		</Container>
	</section>

	<section class="pb-12 pt-2">
		<Container>
			<div class="relative overflow-hidden rounded-[2rem] bg-[linear-gradient(135deg,#08243d,#147c68)] p-6 text-white shadow-[0_34px_90px_-50px_rgba(8,36,61,0.76)] sm:p-7 lg:flex lg:items-center lg:justify-between lg:gap-8">
				<div class="absolute -right-16 -top-16 h-48 w-48 rounded-full bg-brand-gold/24 blur-3xl"></div>
				<div class="relative max-w-2xl">
					<p class="text-sm font-semibold uppercase tracking-[0.18em] text-white/76">Ready to learn more?</p>
					<h2 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
						Find the right service path.
					</h2>
					<p class="mt-3 text-sm leading-6 text-white/80">
						View services, apply, or contact the team.
					</p>
				</div>

				<div class="relative mt-5 flex flex-wrap gap-3 lg:mt-0">
					<ButtonLink href="/services" variant="light">View Services</ButtonLink>
					<ButtonLink
						href="/contact"
						variant="unstyled"
						class="border border-white/30 bg-white/10 px-5 py-3 text-sm text-white hover:-translate-y-0.5 hover:bg-white/18 sm:text-base"
					>
						Contact the Team
					</ButtonLink>
				</div>
			</div>
		</Container>
	</section>
</BaseLayout>
