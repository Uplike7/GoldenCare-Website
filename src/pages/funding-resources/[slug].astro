---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/site/Breadcrumbs.astro";
import Container from "../../components/ui/Container.astro";
import CTASection from "../../components/sections/CTASection.astro";

export async function getStaticPaths() {
	const resources = await getCollection("resources");
	return resources.map((resource) => ({
		params: { slug: resource.id },
		props: { resource }
	}));
}

const { resource } = Astro.props;
const { Content } = await render(resource);
---

<BaseLayout title={`${resource.data.title} | Golden Care Resources`} description={resource.data.description}>
	<Breadcrumbs
		items={[
			{ label: "Home", href: "/" },
			{ label: "Funding & Resources", href: "/funding-resources" },
			{ label: resource.data.title }
		]}
	/>

	<section class="section-padding pb-10 pt-6">
		<Container narrow class="space-y-6">
			<p class="eyebrow">{resource.data.category}</p>
			<h1 class="text-4xl font-semibold tracking-tight text-balance sm:text-5xl">{resource.data.title}</h1>
			<p class="text-lg leading-8 text-slate-600">{resource.data.description}</p>
			<p class="text-sm text-slate-500">
				{resource.data.date.toLocaleDateString("en-CA", { month: "long", day: "numeric", year: "numeric" })} | {resource.data.readingTime}
			</p>
		</Container>
	</section>

	<section class="pb-8">
		<Container narrow class="surface-card p-8 sm:p-10">
			<article class="article-content">
				<Content />
			</article>
		</Container>
	</section>

	<CTASection
		title="Ready for a next step?"
		description="Contact Golden Care or start an application."
		primaryAction={{ href: "/contact", label: "Contact Golden Care" }}
		secondaryAction={{ href: "/apply", label: "Apply for services" }}
	/>
</BaseLayout>
